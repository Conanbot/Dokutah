# Supabase MedCheckup Environment Configuration
# Copy this file to .env and fill in your actual Supabase credentials.
# Get these from your Supabase project dashboard:
# 1. Go to https://supabase.com/dashboard
# 2. Create new project (free tier OK)
# 3. Settings > API > Copy URL and anon key

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional - uncomment for admin operations (Settings > API > service_role key)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Server config
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,*

# Uncomment for direct PostgreSQL (if not using Supabase)
# DB_USER=postgres
# DB_HOST=localhost
# DB_NAME=medcheckup
# DB_PASSWORD=your-db-password
# DB_PORT=5432

# After editing .env:
# 1. cp .env.example .env  (or rename)
# 2. Fill SUPABASE_URL and SUPABASE_ANON_KEY
# 3. node server.js
# 4. Seed data via Supabase dashboard (import db/salatiga_seed.sql)

